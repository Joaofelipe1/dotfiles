{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["hyprland/workspaces", "custom/dolphin", "custom/music"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "custom/power"],

    "hyprland/workspaces": {
        "format": "{id}"
    },
    "clock": {
        "format": "{:%H:%M  %d/%m/%Y}",
        "on-click": "gnome-calendar"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "on-click": "pavucontrol" 
    },
    "custom/power": {
        "format": "⏻",
        "on-click": "wlogout",
        "tooltip": false
    },
    "custom/dolphin": {
        "format": "󰉋",
        "on-click": "dolphin",
        "interval": 0
    },
    "custom/music": {
        "exec": "~/scripts/music.sh",
        "interval": 2
    }

    
}
